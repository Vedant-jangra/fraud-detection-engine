{
  "title": "Fraud Engine Dashboard",
  "panels": [
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(requests_total)" } ]
    },
    {
      "title": "Fraud Alerts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [ { "expr": "sum(fraud_alerts_total)" } ]
    },
    {
      "title": "Inference Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "targets": [ { "expr": "histogram_quantile(0.99, sum(rate(inference_latency_ms_bucket[5m])) by (le))" } ]
    }
  ]
}
